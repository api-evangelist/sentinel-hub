  "properties": {
    "context": {
      "type": "object",
      "required": [
        "returned"
      ],
      "properties": {
        "next": {
          "type": "integer",
          "minimum": 0,
          "example": 1
        },
        "limit": {
          "type": "integer",
          "minimum": 0,
          "example": 1
        },
        "returned": {
          "type": "integer",
          "minimum": 0,
          "example": 1
        }
      }
    }
  }
}