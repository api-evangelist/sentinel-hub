{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://api.sentinel-hub.com/schemas/LandsatFiltering",
  "title": "LandsatFiltering",
  "type": "object",
  "properties": {
    "timeRange": {
      "$ref": "#/components/schemas/TimeRange"
    },
    "mosaickingOrder": {
      "description": "The order in which tiles are overlapped from which the output result is mosaicked.",
      "type": "string",
      "enum": [
        "mostRecent",
        "leastRecent",
        "leastCC"
      ],
      "default": "mostRecent"
    },
    "maxCloudCoverage": {
      "allOf": [
        {
          "$ref": "#/components/schemas/MaxCloudCoverage"
        },
        {
          "default": 100
        }
      ]
    }
  }
}