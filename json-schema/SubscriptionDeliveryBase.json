{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://api.sentinel-hub.com/schemas/SubscriptionDeliveryBase",
  "title": "SubscriptionDeliveryBase",
  "type": "object",
  "properties": {
    "id": {
      "description": "Delivery ID",
      "type": "string",
