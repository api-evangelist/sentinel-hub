  "url": "https://www.sentinel-hub.com/",
  "documentation": "https://docs.sentinel-hub.com/api/latest/",
  "termsOfService": "https://www.sentinel-hub.com/tos/",
  "provider": {
    "@type": "Organization",
    "name": "Sinergise",
    "url": "https://www.sinergise.com/"
  },
  "availableChannel": [
    {
      "@type": "ServiceChannel",
      "serviceUrl": "https://services.sentinel-hub.com"
    }
  ],
  "keywords": [
    "Satellite Imagery",
    "Geospatial",
    "Remote Sensing",
    "Earth Observation",
    "NDVI",
    "Sentinel",
    "Landsat",
